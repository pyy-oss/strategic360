# Cibles de la bascule vers un projet Firebase/GCP NEUF (incident 2026-07 : projet
# sentinel-360 compromis — voir docs/MIGRATION-2.md).
#
# 1. Copier ce fichier en `migration/target.env` (gitignoré — jamais commité).
# 2. Remplir CHAQUE valeur avec celles du NOUVEAU projet (Firebase Console > Paramètres du
#    projet > Général > Vos applications > Web). Les valeurs Firebase web ne sont PAS secrètes
#    (elles identifient le projet ; la sécurité vient de Auth/Rules/App Check), mais elles
#    n'existent qu'une fois le projet + l'app web créés.
# 3. Lancer :  DRY_RUN=1 ./scripts/retarget-project.sh   (vérifier)  puis sans DRY_RUN.
#
# Le script REFUSE de tourner tant qu'une valeur vaut encore le placeholder « CHANGEME ».

# --- Identité du nouveau projet ------------------------------------------------------------
NEW_PROJECT_ID=CHANGEME                 # ex. sentinel-370 — id GCP globalement unique
NEW_DB_ID=sentinel360                   # base Firestore NOMMÉE (recommandé : garder sentinel360)
NEW_HOSTING_SITE=CHANGEME               # site Hosting (globalement unique), ex. sentinelnt-370
NEW_REGION=europe-west1                 # NE PAS changer sans raison (données/latence UE)

# --- Buckets (dérivables du project id, mais globalement uniques → à confirmer) ------------
NEW_STORAGE_BUCKET=CHANGEME.firebasestorage.app   # bucket par défaut du nouveau projet
NEW_BACKUP_BUCKET=CHANGEME-backups                # export Firestore quotidien (à créer)

# --- Config Firebase Web du nouveau projet (publique, non secrète) -------------------------
NEW_API_KEY=CHANGEME                    # AIza… (clé web du nouveau projet)
NEW_AUTH_DOMAIN=CHANGEME.firebaseapp.com
NEW_MESSAGING_SENDER_ID=CHANGEME        # numéro de projet (n°), ex. 876373263153
NEW_APP_ID=CHANGEME                     # 1:<sender>:web:<hash>

# --- Lecture cross-projet nt360 (source du quanti interne) ---------------------------------
# Inchangé par la bascule Sentinel : nt360 vit toujours dans propulse-business-87f7a (ou son
# projet dédié neurones-360 si déjà migré). Ne PAS mettre le nouveau projet ici.
NEW_NT360_PROJECT_ID=propulse-business-87f7a
NEW_NT360_DATABASE_ID=nt360
