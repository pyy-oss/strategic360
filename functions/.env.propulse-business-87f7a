# via the Identity Toolkit REST API (.github/workflows/set-user-role.yml hardcodes the same value
# since that workflow doesn't load this file automatically — keep both in sync).
FIREBASE_WEB_API_KEY=AIzaSyBHxv2ThBh66hRc1Lp_boTlzeB8LA37FF8
