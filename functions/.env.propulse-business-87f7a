# Cloud Functions deploy config for the shared "propulse-business-87f7a" Firebase project.
# Loaded automatically by `firebase deploy`/emulators when .firebaserc's default project (or
# --project) is "propulse-business-87f7a". Non-secret — see functions/.env.example for context.
#
# This app is one of several sharing this project. These two vars route every Firestore/Storage
# call in this codebase to its own dedicated database/bucket, so it can never read, write, or
# overwrite another app's data in this project.

FIRESTORE_DATABASE_ID=strategic360
STORAGE_BUCKET_NAME=strategic360
APPCHECK_ENFORCE=false

# NOTE: the web API key used by functions/adminSetUserRole.js (to send password-setup emails)
# is intentionally NOT defined here — firebase-tools rejects any .env.<project> key starting with
# "FIREBASE_" (reserved prefix: X_GOOGLE_/FIREBASE_/EXT_), which broke `firebase deploy` when this
# used to live here as FIREBASE_WEB_API_KEY. It's set directly as a step env var in
# .github/workflows/set-user-role.yml instead, where that restriction doesn't apply.
