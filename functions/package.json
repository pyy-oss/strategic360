{
  "name": "functions",
  "private": true,
  "engines": {
    "node": "22"
  },
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "lint": "eslint .",
    "test": "vitest run",
    "test:unit": "vitest run --exclude '**/firestore.rules.test.js'",
    "test:rules": "firebase emulators:exec --only firestore --config ../firebase.json --project demo-veille \"vitest run test/firestore.rules.test.js\"",
    "serve": "firebase emulators:start --only functions"
  },
  "dependencies": {
    "@google-cloud/firestore": "^7.11.0",
    "@google/genai": "^2.0.0",
    "@sparticuz/chromium": "^131.0.1",
    "exceljs": "^4.4.0",
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^7.0.0",
    "pdfkit": "^0.15.0",
    "puppeteer-core": "^23.11.1"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.15.0",
    "vitest": "^2.0.0"
  }
}
