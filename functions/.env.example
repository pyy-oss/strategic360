# Cloud Functions v2 environment config. Firebase automatically loads:
#   functions/.env                    — applies to every project
#   functions/.env.<project-id>       — applies only when deploying to that project
#   functions/.env.local              — local emulator overrides only, never deployed
# (all of these are loaded at deploy/emulator time; see
# https://firebase.google.com/docs/functions/config-env)
#
# These two vars exist for SHARED-PROJECT ISOLATION: when this Firebase project also hosts other
# apps, point this codebase at a dedicated named Firestore database and a dedicated Storage bucket
# so it never reads/writes/overwrites another app's data. See index.js's matching comment.

# A named Firestore database (Firebase Console > Firestore > Database dropdown > Create database).
# MUST match the client's VITE_FIREBASE_FIRESTORE_DATABASE_ID (web/.env.example).
# REQUIRED (audit 2026-07, M2) : functions refuse to start without it — no more silent fallback
# to "(default)". For a dedicated single-app project that really wants the default database, set
# ALLOW_DEFAULT_DATABASE=true instead of leaving this empty.
FIRESTORE_DATABASE_ID=
# ALLOW_DEFAULT_DATABASE=true

# A dedicated Cloud Storage bucket (Firebase Console > Storage > Add a bucket, or an existing
# non-default bucket). MUST match firebase.json's "storage.bucket".
STORAGE_BUCKET_NAME=

# App Check enforcement toggle — see index.js's ENFORCE_APP_CHECK comment for the safe rollout
# order (client must be sending App Check tokens BEFORE this flips to "true").
APPCHECK_ENFORCE=false

# Vertex AI region (V7 IA & sync) — see domain/vertex.js.
VERTEX_LOCATION=us-central1

# Daily Firestore export (scheduledFirestoreExport) — a bucket DEDICATED to this app (audit
# 2026-07, M1 : never the shared appspot default bucket). Export is SKIPPED (with an error log)
# while this is unset.
FIRESTORE_EXPORT_BUCKET=

# One-time role bootstrap (audit 2026-07, M3) : setUserRole's first-`direction` bootstrap path is
# DISABLED unless this is "true". Set it temporarily for the very first deployment of a fresh
# client project, create the first direction account (self-assign, authenticated), then remove.
# ALLOW_ROLE_BOOTSTRAP=true

# Rétention de auditLog en jours (audit 2026-07, m15) — purgeAuditLog supprime chaque semaine les
# entrées plus anciennes. Défaut 730 (2 ans). Adapter selon la politique de conservation du client.
# AUDITLOG_RETENTION_DAYS=730

# Plafond d'instances Cloud Run (maîtrise des coûts) — appliqué globalement via setGlobalOptions.
# Sans plafond, chaque fonction peut monter à 100 instances : une facture qui s'emballe sur un pic.
# Défaut 10. Aucun minInstances n'est posé (scale-to-zéro conservé — pas d'instance chaude 24/7).
# MAX_INSTANCES=10
#
# NB : la CADENCE des pipelines IA (sync/évaluation/agrégat/enrichissement/briefing) — principal
# levier de coût Vertex — se règle EN DIRECT depuis l'app (Détection > « Cadence & coûts IA »,
# exécutifs), stockée dans config/runtime. Pas de variable d'environnement ni de redéploiement.
