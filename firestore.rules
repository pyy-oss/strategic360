rules_version = '2';

// Security Rules for "Veille Stratégique" (Neurones Technologies CI).
// Ported from docs/BUILD_KIT.md §7, with the `match … where c in […]` shorthand expanded
// into one explicit `match` block per collection (Firestore rules do not support that syntax).
//
// NOTE (V0): these rules are committed as part of the project skeleton but are NOT yet wired
// to real Auth/custom-claims usage in the app (that's V1 per the roadmap). They already reflect
// the intended RBAC model so V1 can turn them on without redesigning the schema.
service cloud.firestore {
  match /databases/{db}/documents {

    function role() { return request.auth.token.role; }
    function matrix() { return get(/databases/$(db)/documents/config/permissions).data.matrix; }
    function lvl(m) { return role() in ['direction'] ? 'write' : matrix()[role()][m]; }
    function canRead(m) { return request.auth != null && lvl(m) in ['read', 'write']; }
    function canWrite(m) { return request.auth != null && lvl(m) == 'write'; }
    function exec() { return role() in ['direction', 'strategie', 'innovation']; }
    // Copilote Commercial (add-on) : rôles commerciaux + exécutifs.
    function commercial() { return request.auth != null && role() in ['commercial', 'commercial_dir', 'direction', 'strategie', 'innovation']; }
    // Rôles NON cloisonnés (voient tout le portefeuille) : directeurs commerciaux + exécutifs.
    function copiloteUnscoped() { return request.auth != null && role() in ['commercial_dir', 'direction', 'strategie', 'innovation']; }
    // Compte rattaché à l'appelant (audit 2026-07) : rôle non cloisonné, OU créateur, OU e-mail dans
    // `owners` (normalisé en minuscule côté serveur). NB : le rattachement am/BU ne peut PAS être
    // rejoué en règles (il exige copiloteProfiles) — l'édition directe est donc limitée au créateur/
    // owner ; le cloisonnement complet reste servi par le callable Admin (listCopiloteAccounts).
    function copiloteOwned() {
      return copiloteUnscoped()
        || resource.data.get('createdBy', '') == request.auth.uid
        || (request.auth.token.email != null && request.auth.token.email.lower() in resource.data.get('owners', []));
    }

    // — Signaux & détection —
    match /intelItems/{id} {
      allow read: if canRead('veille');
      allow create: if canWrite('veille') && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if canWrite('veille');
    }
    match /intelWatchlist/{id} {
      allow read: if canRead('veille');
      allow write: if canWrite('veille');
    }
    match /intelSources/{id} {
      allow read: if canRead('veille');
      allow write: if exec();
    }

    // — Cadres & analyse —
    match /frameworks/{key} {
      allow read: if canRead('veille');
      allow write: if exec();
    }

    // Expanded from: match /{c}/{id} where c in ['scenarios','decisions','strategicThemes','initiatives']
    match /scenarios/{id} {
      allow read: if canRead('veille');
      allow write: if exec();
    }
    match /decisions/{id} {
      allow read: if canRead('veille');
      allow write: if exec();
    }
    match /strategicThemes/{id} {
      allow read: if canRead('veille');
      allow write: if exec();
    }
    match /initiatives/{id} {
      allow read: if canRead('veille');
      allow write: if exec();
    }

    // Expanded from: match /{c}/{id} where c in ['techRadar','innovationPortfolio']
    match /techRadar/{id} {
      allow read: if canRead('veille');
      allow write: if role() in ['direction', 'innovation'];
    }
    match /innovationPortfolio/{id} {
      allow read: if canRead('veille');
      allow write: if role() in ['direction', 'innovation'];
    }

    match /battlecards/{id} {
      allow read: if canRead('veille');
      allow write: if canWrite('veille');
    }

    // — Opportunités business (créées par runEnrichment via Admin SDK, qui bypasse les rules) —
    // Les exécutifs qualifient (update de status/notes) ; create/delete restent réservés au
    // backend pour que le pipeline IA garde la maîtrise du cycle de vie des docs.
    match /bizOpportunities/{id} {
      allow read: if canRead('veille');
      allow update: if exec();
      allow create, delete: if false;
    }

    // Expanded from: match /{c}/{id} where c in ['winLoss','actions','briefings']
    // Win/Loss : le commercial qui VIT le deal doit pouvoir l'enregistrer (audit 2026-07) — aligné
    // sur les battlecards (canWrite('veille')) au lieu du gate exec, avec createdBy imposé à la création.
    match /winLoss/{id} {
      allow read: if canRead('veille');
      allow create: if canWrite('veille') && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if canWrite('veille');
    }
    match /actions/{id} {
      allow read: if canRead('veille');
      allow write: if exec();
    }
    match /briefings/{id} {
      allow read: if canRead('veille');
      allow write: if exec();
    }

    // — Copilote Commercial : comptes (qualitatif édité par les commerciaux) —
    // Le sous-objet `nt360` (empreinte dérivée du pipeline) est écrit UNIQUEMENT par les Cloud
    // Functions (Admin SDK, qui outrepasse ces règles). Côté client, un commercial peut lire, créer,
    // supprimer et éditer le QUALITATIF, mais ne peut pas écrire/écraser `nt360` — sinon une simple
    // requête client pourrait corrompre les vraies données de pipeline jusqu'à la prochaine synchro.
    // Lecture DIRECTE réservée aux rôles non cloisonnés ; le rôle « commercial » simple lit son
    // portefeuille via le callable listCopiloteAccounts (Admin SDK), qui applique son périmètre —
    // impossible de contourner le cloisonnement par une requête client. `nt360` et `owners` sont des
    // champs SERVEUR : jamais écrits depuis le client (empreinte pipeline + attribution).
    match /copiloteAccounts/{id} {
      allow read: if copiloteUnscoped();
      // Écriture directe cloisonnée (audit 2026-07) : un commercial simple ne peut supprimer/éditer
      // QUE les comptes qui lui sont rattachés (créateur/owner), plus jamais un compte hors périmètre.
      allow delete: if commercial() && copiloteOwned();
      // `createdBy`, s'il est fourni, doit être l'appelant (un commercial ne peut pas attribuer un
      // compte à autrui via createdBy) ; `nt360`/`owners` restent réservés au serveur.
      allow create: if commercial()
        && !('nt360' in request.resource.data) && !('owners' in request.resource.data)
        && (!('createdBy' in request.resource.data) || request.resource.data.createdBy == request.auth.uid);
      allow update: if commercial() && copiloteOwned()
        && !('nt360' in request.resource.data.diff(resource.data).affectedKeys())
        && !('owners' in request.resource.data.diff(resource.data).affectedKeys())
        && (!('createdBy' in request.resource.data.diff(resource.data).affectedKeys())
            || request.resource.data.createdBy == request.auth.uid);
    }

    // — Copilote : périmètres de cloisonnement par commercial (clé = e-mail ; écrits par callable
    // Admin uniquement). Lecture réservée au propriétaire du périmètre ou aux admins (audit 2026-07 :
    // le périmètre d'un collègue — ses am/BU — ne doit pas être lisible par tout le monde). La liste
    // admin (PerimetresPanel) reste autorisée car la clause admin est indépendante du document.
    match /copiloteProfiles/{email} {
      allow read: if request.auth != null
        && (role() in ['direction', 'commercial_dir'] || request.auth.token.email == email);
      allow write: if false;
    }

    // — Agrégats (écrits par Cloud Functions / Admin SDK uniquement) —
    match /summaries/{d} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // — Config & sécurité —
    match /config/permissions {
      allow read: if request.auth != null;
      allow write: if role() == 'direction';
    }
    match /config/{d} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /auditLog/{id} {
      allow read: if role() == 'direction';
      allow write: if false;
    }
    match /users/{uid} {
      allow read: if role() == 'direction' || request.auth.uid == uid;
      allow write: if false;
    }

    // — Imports (écrits par ingestInternal via Admin SDK ; lecture réservée exécutifs) —
    match /imports/{id} {
      allow read: if exec();
      allow write: if false;
    }
  }
}
