rules_version = '2';

// Security Rules for "Veille Stratégique" (Neurones Technologies CI).
// Ported from docs/BUILD_KIT.md §7, with the `match … where c in […]` shorthand expanded
// into one explicit `match` block per collection (Firestore rules do not support that syntax).
//
// NOTE (V0): these rules are committed as part of the project skeleton but are NOT yet wired
// to real Auth/custom-claims usage in the app (that's V1 per the roadmap). They already reflect
// the intended RBAC model so V1 can turn them on without redesigning the schema.
service cloud.firestore {
  match /databases/{db}/documents {

    function role() { return request.auth.token.role; }
    function matrix() { return get(/databases/$(db)/documents/config/permissions).data.matrix; }
    function lvl(m) { return role() in ['direction'] ? 'write' : matrix()[role()][m]; }
    function canRead(m) { return request.auth != null && lvl(m) in ['read', 'write']; }
    function canWrite(m) { return request.auth != null && lvl(m) == 'write'; }
    function exec() { return role() in ['direction', 'strategie', 'innovation']; }
    // Copilote Commercial (add-on) : rôles commerciaux (dont ingénieur avant-vente) + exécutifs.
    function commercial() { return request.auth != null && role() in ['commercial', 'commercial_dir', 'avant_vente', 'direction', 'strategie', 'innovation']; }
    // Rôles NON cloisonnés (voient tout le portefeuille) : directeurs commerciaux + exécutifs.
    function copiloteUnscoped() { return request.auth != null && role() in ['commercial_dir', 'direction', 'strategie', 'innovation']; }
    // Compte rattaché à l'appelant (audit 2026-07) : rôle non cloisonné, OU créateur, OU e-mail dans
    // `owners` (normalisé en minuscule côté serveur). NB : le rattachement am/BU ne peut PAS être
    // rejoué en règles (il exige copiloteProfiles) — l'édition directe est donc limitée au créateur/
    // owner ; le cloisonnement complet reste servi par le callable Admin (listCopiloteAccounts).
    function copiloteOwned() {
      return copiloteUnscoped()
        || resource.data.get('createdBy', '') == request.auth.uid
        || (request.auth.token.email != null && request.auth.token.email.lower() in resource.data.get('owners', []));
    }

    // — Signaux & détection —
    match /intelItems/{id} {
      allow read: if canRead('veille');
      allow create: if canWrite('veille') && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if canWrite('veille');
    }
    match /intelWatchlist/{id} {
      allow read: if canRead('veille');
      allow write: if canWrite('veille');
    }
    match /intelSources/{id} {
      allow read: if canRead('veille');
      allow write: if exec();
    }

    // — Cadres & analyse (module `strategie`) — RBAC décomposé : les cadres/scénarios/décisions/OKR
    // relèvent du module stratégie (lecture/écriture selon la matrice), plus du module veille. Un
    // profil sans droit `strategie` (commercial, finance, achats, rh…) ne voit donc plus ces vues.
    match /frameworks/{key} {
      allow read: if canRead('strategie');
      allow write: if canWrite('strategie');
    }

    // Expanded from: match /{c}/{id} where c in ['scenarios','decisions','strategicThemes','initiatives']
    match /scenarios/{id} {
      allow read: if canRead('strategie');
      allow write: if canWrite('strategie');
    }
    match /decisions/{id} {
      allow read: if canRead('strategie');
      allow write: if canWrite('strategie');
    }
    match /strategicThemes/{id} {
      allow read: if canRead('strategie');
      allow write: if canWrite('strategie');
    }
    match /initiatives/{id} {
      allow read: if canRead('strategie');
      allow write: if canWrite('strategie');
    }

    // — Tech Radar & Innovation (module `innovation`) —
    match /techRadar/{id} {
      allow read: if canRead('innovation');
      allow write: if canWrite('innovation');
    }
    match /innovationPortfolio/{id} {
      allow read: if canRead('innovation');
      allow write: if canWrite('innovation');
    }

    match /battlecards/{id} {
      allow read: if canRead('veille');
      allow write: if canWrite('veille');
    }

    // — Opportunités business (créées par runEnrichment via Admin SDK, qui bypasse les rules) —
    // Les exécutifs qualifient (update de status/notes) ; create/delete restent réservés au
    // backend pour que le pipeline IA garde la maîtrise du cycle de vie des docs.
    match /bizOpportunities/{id} {
      allow read: if canRead('veille');
      allow update: if canWrite('innovation');
      allow create, delete: if false;
    }

    // Expanded from: match /{c}/{id} where c in ['winLoss','actions','briefings']
    // Win/Loss : le commercial qui VIT le deal doit pouvoir l'enregistrer (audit 2026-07) — aligné
    // sur les battlecards (canWrite('veille')) au lieu du gate exec, avec createdBy imposé à la création.
    match /winLoss/{id} {
      allow read: if canRead('veille');
      allow create: if canWrite('veille') && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if canWrite('veille');
    }
    match /actions/{id} {
      allow read: if canRead('veille');
      // Adoption (audit doubler-CA) : un commercial doit pouvoir enregistrer ce qu'il a à faire.
      // Il crée ses propres actions (createdBy imposé à lui-même) et n'édite/supprime que les siennes ;
      // les exec gardent la main sur toutes. Sans ça, l'outil n'entre pas dans la routine quotidienne.
      allow create: if commercial() && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if exec() || (commercial() && resource.data.createdBy == request.auth.uid);
    }
    match /briefings/{id} {
      allow read: if canRead('veille');
      allow write: if exec();
    }

    // — Copilote Commercial : comptes (qualitatif édité par les commerciaux) —
    // Le sous-objet `nt360` (empreinte dérivée du pipeline) est écrit UNIQUEMENT par les Cloud
    // Functions (Admin SDK, qui outrepasse ces règles). Côté client, un commercial peut lire, créer,
    // supprimer et éditer le QUALITATIF, mais ne peut pas écrire/écraser `nt360` — sinon une simple
    // requête client pourrait corrompre les vraies données de pipeline jusqu'à la prochaine synchro.
    // Lecture DIRECTE réservée aux rôles non cloisonnés ; le rôle « commercial » simple lit son
    // portefeuille via le callable listCopiloteAccounts (Admin SDK), qui applique son périmètre —
    // impossible de contourner le cloisonnement par une requête client. `nt360` et `owners` sont des
    // champs SERVEUR : jamais écrits depuis le client (empreinte pipeline + attribution).
    match /copiloteAccounts/{id} {
      allow read: if copiloteUnscoped();
      // Écriture directe cloisonnée (audit 2026-07) : un commercial simple ne peut supprimer/éditer
      // QUE les comptes qui lui sont rattachés (créateur/owner), plus jamais un compte hors périmètre.
      allow delete: if commercial() && copiloteOwned();
      // `createdBy`, s'il est fourni, doit être l'appelant (un commercial ne peut pas attribuer un
      // compte à autrui via createdBy) ; `nt360`/`owners` restent réservés au serveur.
      allow create: if commercial()
        && !('nt360' in request.resource.data) && !('owners' in request.resource.data)
        && (!('createdBy' in request.resource.data) || request.resource.data.createdBy == request.auth.uid);
      allow update: if commercial() && copiloteOwned()
        && !('nt360' in request.resource.data.diff(resource.data).affectedKeys())
        && !('owners' in request.resource.data.diff(resource.data).affectedKeys())
        && (!('createdBy' in request.resource.data.diff(resource.data).affectedKeys())
            || request.resource.data.createdBy == request.auth.uid);
    }

    // — Copilote : périmètres de cloisonnement par commercial (clé = e-mail ; écrits par callable
    // Admin uniquement). Lecture réservée au propriétaire du périmètre ou aux admins (audit 2026-07 :
    // le périmètre d'un collègue — ses am/BU — ne doit pas être lisible par tout le monde). La liste
    // admin (PerimetresPanel) reste autorisée car la clause admin est indépendante du document.
    match /copiloteProfiles/{email} {
      allow read: if request.auth != null
        && (role() in ['direction', 'commercial_dir'] || request.auth.token.email == email);
      allow write: if false;
    }

    // — Agrégats (écrits par Cloud Functions / Admin SDK uniquement) —
    // Audit intégral 2026-07 (m3) : les agrégats EXÉCUTIFS/FINANCIERS ne sont lisibles que par les
    // exécutifs. `summaries/veille_exec` (taux de victoire par concurrent, pipeline en XOF, KPIs
    // board) et `summaries/quanti` (données financières dérivées de l'app sœur nt360) étaient
    // exposés à tout rôle authentifié (commercial cloisonné, pmo, achats, lecture) — incohérent
    // avec le durcissement config/*. Les autres agrégats (summaries/veille, aiHealth, syncStatus)
    // restent lisibles par tous les authentifiés (fil/radar/santé).
    // NB : les blocs `match` Firestore se combinent en OU — une règle spécifique restrictive ne peut
    // pas « surcharger » une règle générale permissive. On exprime donc la restriction DANS l'unique
    // règle summaries/{d} : veille_exec & quanti exigent exec(), les autres agrégats restent
    // lisibles par tout authentifié.
    // RBAC décomposé : les agrégats FINANCIERS (veille_exec, quanti, kpiHistory) relèvent du module
    // `finance` (DAF, achats, direction commerciale, exécutifs — selon la matrice), plus seulement
    // des exécutifs. Les autres agrégats (veille, aiHealth, syncStatus) restent lisibles par tout
    // authentifié (fil/radar/santé).
    // Durcissement (audit 4 zones 2026-07) : la règle unique ne cloisonnait QUE les agrégats
    // financiers. Or `copiloteClientValue`/`copiloteMeta` (classement clients, cross-sell, churn) sont
    // du domaine `copilote`, et `digestStatus` est l'état interne du canal sortant — aucun n'a à être
    // lisible par un rôle sans droit copilote (ex. technique). `veille`/`aiHealth`/`syncStatus` restent
    // ouverts (fil/radar/santé). Aucun code client ne lit copilote*/digestStatus (grep web = 0).
    match /summaries/{d} {
      allow read: if request.auth != null && (
        (d in ['veille_exec', 'quanti', 'kpiHistory']) ? canRead('finance')
        : (d in ['copiloteClientValue', 'copiloteMeta']) ? canRead('copilote')
        : (d == 'digestStatus') ? exec()
        : true
      );
      allow write: if false;
    }

    // Cibles commerciales (waouh v2 — pilotage de la performance). nt360 étant en lecture seule, les
    // objectifs/quotas par commercial vivent ici (base strategic360), éditables par les MANAGERS
    // (direction commerciale + exécutifs) et lisibles par eux seuls.
    match /salesTargets/{d} {
      allow read: if request.auth != null && (exec() || role() == 'commercial_dir');
      allow write: if request.auth != null && (exec() || role() == 'commercial_dir');
    }

    // Contenu marketing (levier « waouh » n°2 — persistance & calendrier éditorial). Les angles de
    // contenu générés par l'IA (Copilote > Contenu marketing) sont volatiles tant qu'on ne les
    // enregistre pas : ici on les persiste en backlog éditorial (statut idée/planifié/publié, date
    // de programmation). Même audience que l'add-on Copilote qui les produit : rôles commerciaux +
    // exécutifs. `createdBy` imposé à l'appelant à la création ; chacun édite/supprime les siens,
    // les exécutifs gardent la main sur tout (revue éditoriale).
    // RBAC décomposé : co-géré par le module `marketing` (Direction/Chargé marketing = write) ET les
    // rôles commerciaux (qui génèrent des angles dans le Copilote et enregistrent les leurs). Un
    // profil marketing pilote tout le calendrier ; un commercial n'édite/supprime que ses créations.
    match /marketingContent/{id} {
      allow read: if canRead('marketing') || commercial();
      allow create: if (canWrite('marketing') || commercial()) && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if canWrite('marketing') || exec() || (commercial() && resource.data.createdBy == request.auth.uid);
    }

    // — Config & sécurité —
    match /config/permissions {
      allow read: if request.auth != null;
      allow write: if role() == 'direction';
    }
    // Pondérations de focale (rôle-focale × axe) : lisibles par TOUT authentifié (le front en a besoin
    // pour le tri par focale, comme config/permissions). Écriture via le callable setLensWeights (Admin SDK).
    match /config/lensWeights {
      allow read: if request.auth != null;
      allow write: if false;
    }
    // Audit pré-lancement 2026-07 (M4) : les autres docs config/* (profil client, taxonomie,
    // scoring, brouillon d'onboarding — qui contient le crawl concurrentiel et l'analyse IA) ne
    // sont lisibles que par les EXÉCUTIFS. `config/permissions` reste lisible par tout utilisateur
    // authentifié (règle dédiée ci-dessus) car le front en a besoin pour évaluer la matrice RBAC.
    match /config/{d} {
      allow read: if request.auth != null && exec();
      allow write: if false;
    }
    match /auditLog/{id} {
      allow read: if role() == 'direction';
      allow write: if false;
    }
    match /users/{uid} {
      allow read: if role() == 'direction' || request.auth.uid == uid;
      allow write: if false;
    }

    // — Imports (écrits par ingestInternal via Admin SDK ; lecture = module `finance`, données P&L) —
    match /imports/{id} {
      allow read: if canRead('finance');
      allow write: if false;
    }

    // — Webhooks / intégrations tierces —
    // Ces docs contiennent des SECRETS partagés (HMAC) : jamais lisibles côté client, même par la
    // Direction. Toute la gestion passe par les callables `webhookAdmin` (secrets masqués) et le
    // endpoint `webhookInbound`, qui écrivent via l'Admin SDK (les règles ne s'y appliquent pas).
    match /webhookEndpoints/{id}      { allow read, write: if false; }
    match /webhookInboundSources/{id} { allow read, write: if false; }
    match /webhookDeliveries/{id}     { allow read, write: if false; }
    match /webhookInboundLog/{id}     { allow read, write: if false; }
  }
}
