# Firebase client SDK config — copy to .env.local and fill in with the real
# values from Firebase Console > Project settings > General > Your apps > Web app.
# (.env.local is gitignored; never commit real credentials.)
#
# In this sandbox no real Firebase project is provisioned — the app falls back
# to a harmless "not configured" state (see src/lib/firebase.ts) so `npm run
# build`/`typecheck` keep working without these vars set.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# App Check (V8 Durcissement) — reCAPTCHA v3 site key, Firebase Console > App Check > Apps >
# register this web app > reCAPTCHA v3 > site key. Optional: if left blank, App Check is simply
# not enabled client-side (see src/lib/firebase.ts) — safe for local dev / this sandbox. Set this
# BEFORE turning on `enforceAppCheck` server-side in functions/index.js, else all callables will
# be rejected for every client.
VITE_FIREBASE_APPCHECK_SITE_KEY=

# Shared-project isolation — set this ONLY if this Firebase project also hosts other apps and you
# created a dedicated named Firestore database for this one (Firebase Console > Firestore >
# Database dropdown > Create database, name it e.g. "strategic360"). Leave blank to use the
# project's normal "(default)" database. MUST match functions/.env's FIRESTORE_DATABASE_ID, or the
# client and Cloud Functions will silently read/write two different databases.
VITE_FIREBASE_FIRESTORE_DATABASE_ID=
